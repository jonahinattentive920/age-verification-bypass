{
    "manifest_version": 3,
    "name": "AgeChecker.net bypass",
    "version": "1.0",
    "description": "Skips the agechecker.net verification screen! You should never send your ID online.",
    "author": "🦊 helloyanis",
    "developer": {
        "name": "🦊 helloyanis",
        "url": "https://🦊💻️.ws"
    },
    "browser_specific_settings": {
        "gecko": {
          "id": "helloyanis@ageverif-bypass",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "webRequest",
